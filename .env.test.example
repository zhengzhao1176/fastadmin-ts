# Test / dev environment configuration.
# Copy this file to `.env.test` and adjust the values for your machine.
# `.env.test` is git-ignored — never commit real credentials.

# ---- HTTP server ----
# Base URL the black-box test suite targets. Point this at the running
# FastAdmin instance (the PHP reference, or the TS server) under test.
FASTADMIN_BASE_URL=http://127.0.0.1:8787

# ---- MySQL ----
DB_HOST=127.0.0.1
DB_PORT=3787
DB_NAME=fastadmin_test
DB_USER=fastadmin_test
DB_PASSWORD=change_me
DB_ROOT_PASSWORD=change_me_root
DB_PREFIX=fa_

# ---- Redis ----
REDIS_HOST=127.0.0.1
REDIS_PORT=6787
REDIS_DB=0

# ---- Stack mode: docker | local ----
STACK=docker

# ---- Optional: error tracking ----
# When set, the server forwards errors to Sentry (backend + browser SDK).
# Leave empty to disable.
# SENTRY_DSN=

# ---- Optional: upload tuning (see doc/177.html) ----
# UPLOAD_SAVEKEY=/uploads/{year}{mon}{day}/{filemd5}{.suffix}
# UPLOAD_MAXSIZE=10mb
# UPLOAD_MIMETYPE=*
# UPLOAD_CHUNKING=true
